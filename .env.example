# Copy to `.env` and fill in values. Never commit `.env`.

# Required: public URL Twilio can reach (no trailing slash).
# Local: https://your-subdomain.ngrok.app
# Production: https://voice.example.com
PUBLIC_URL=

PORT=5050

# openai | azure
REALTIME_PROVIDER=openai

# --- OpenAI (REALTIME_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime

# --- Azure OpenAI (REALTIME_PROVIDER=azure) ---
# Endpoint like https://your-resource.openai.azure.com (no trailing slash)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Twilio (voice webhook signature validation)
TWILIO_AUTH_TOKEN=
# Set false only if signature validation fails during local tunnel testing.
TWILIO_VALIDATE_SIGNATURE=true

# Assistant voice + instructions (Realtime GA schema)
REALTIME_VOICE=alloy
ASSISTANT_INSTRUCTIONS=
